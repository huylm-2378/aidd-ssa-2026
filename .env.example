# ISO-8601 event-start datetime driving the Homepage SAA countdown (client-side).
# Missing/malformed value -> countdown safely renders elapsed state (all 00). See BR-003.
NEXT_PUBLIC_SAA_EVENT_START="2025-12-26T18:30:00+07:00"

# Supabase project — Google OAuth (F005). Values live in gitignored .env (never commit real keys).
# From Supabase Dashboard -> Project Settings -> API. Use the anon / publishable key (NOT service_role).
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-or-publishable-key>"
